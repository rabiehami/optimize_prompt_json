{
  "type": "object",
  "properties": {
    "location": {
      "type": "string",
      "description": "City and region name"
    },
    "date": {
      "type": "string",
      "description": "Forecast date in YYYY-MM-DD format"
    },
    "temperature": {
      "type": "object",
      "properties": {
        "high": { "type": "number", "description": "High temperature in Fahrenheit" },
        "low": { "type": "number", "description": "Low temperature in Fahrenheit" }
      },
      "required": ["high", "low"]
    },
    "conditions": {
      "type": "string",
      "description": "Weather conditions summary (e.g., 'Partly cloudy with afternoon showers')"
    },
    "humidity": {
      "type": "integer",
      "description": "Relative humidity percentage"
    },
    "windSpeed": {
      "type": "string",
      "description": "Wind speed and direction (e.g., 'NW 15 mph')"
    },
    "alerts": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Active weather alerts or advisories"
    }
  },
  "required": ["location", "date", "temperature", "conditions", "humidity", "windSpeed"]
}
